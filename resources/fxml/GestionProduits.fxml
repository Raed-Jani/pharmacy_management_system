<!-- ========== GestionProduits.fxml ========== -->
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.ui.controller.GestionProduitsController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Titre -->
                <Label text="Gestion des Produits" styleClass="page-title" />

                <!-- Barre de recherche -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="txtRecherche" promptText="Rechercher un produit..." HBox.hgrow="ALWAYS" />
                        <Button text="🔍 Rechercher" onAction="#handleRechercher" />
                        <Button text="⚠️ Alertes" onAction="#handleAlertes" styleClass="btn-warning" />
                        <Label fx:id="lblStatut" text="0 produit(s)" />
                    </children>
                </HBox>

                <!-- Séparation en deux colonnes -->
                <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">
                    <items>
                        <!-- Colonne gauche: Liste des produits -->
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Liste des produits" styleClass="section-title" />
                                <TableView fx:id="tableProduits" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" text="ID" prefWidth="50.0" />
                                        <TableColumn fx:id="colNom" text="Nom" prefWidth="200.0" />
                                        <TableColumn fx:id="colCodeBarre" text="Code-barres" prefWidth="120.0" />
                                        <TableColumn fx:id="colPrix" text="Prix (TND)" prefWidth="80.0" />
                                        <TableColumn fx:id="colStock" text="Stock" prefWidth="70.0" />
                                        <TableColumn fx:id="colSeuil" text="Seuil" prefWidth="70.0" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <!-- Colonne droite: Formulaire -->
                        <VBox spacing="10.0">
                            <children>
                                <Label text="Détails du produit" styleClass="section-title" />

                                <GridPane hgap="10.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" />
                                    </columnConstraints>

                                    <Label text="Nom:" GridPane.rowIndex="0" />
                                    <TextField fx:id="txtNom" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                    <Label text="Description:" GridPane.rowIndex="1" />
                                    <TextArea fx:id="txtDescription" prefRowCount="3" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                    <Label text="Code-barres:" GridPane.rowIndex="2" />
                                    <TextField fx:id="txtCodeBarre" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                    <Label text="Prix unitaire:" GridPane.rowIndex="3" />
                                    <TextField fx:id="txtPrix" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                    <Label text="Quantité stock:" GridPane.rowIndex="4" />
                                    <TextField fx:id="txtStock" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                    <Label text="Seuil alerte:" GridPane.rowIndex="5" />
                                    <TextField fx:id="txtSeuil" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                </GridPane>

                                <HBox spacing="10.0" alignment="CENTER">
                                    <children>
                                        <Button fx:id="btnAjouter" text="Ajouter" onAction="#handleAjouter" prefWidth="100.0" styleClass="btn-success" />
                                        <Button fx:id="btnModifier" text="Modifier" onAction="#handleModifier" prefWidth="100.0" styleClass="btn-primary" />
                                        <Button fx:id="btnSupprimer" text="Supprimer" onAction="#handleSupprimer" prefWidth="100.0" styleClass="btn-danger" />
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </items>
                </SplitPane>
            </children>
        </VBox>
    </children>
</AnchorPane>