<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.pharmacie.ui.controller.GestionVentesController" 
            stylesheets="@../css/style.css"
            prefHeight="700.0" prefWidth="1100.0">
    
    <TabPane tabClosingPolicy="UNAVAILABLE" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" 
             AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        
        <!-- TAB 1: Nouvelle Vente -->
        <Tab text="➕ Nouvelle Vente">
            <BorderPane>
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <left>
                    <VBox spacing="15" prefWidth="550" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-background-radius: 5;">
                        <Label text="📚 Catalogue Produits" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #F5F6FA; -fx-padding: 10; -fx-background-radius: 5;">
                            <Label text="🔍" style="-fx-font-size: 16px;"/>
                            <TextField fx:id="fieldRechercheProduit" promptText="Rechercher par nom, code barre..." HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-width: 0 0 1 0; -fx-border-color: #BDC3C7;"/>
                        </HBox>
                        
                        <TableView fx:id="tableProduits" VBox.vgrow="ALWAYS" style="-fx-base: white; -fx-border-color: #ECF0F1;">
                            <columns>
                                <TableColumn fx:id="colNomProduit" text="Désignation" prefWidth="250"/>
                                <TableColumn fx:id="colPrixProduit" text="Prix Unit." prefWidth="100" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                                <TableColumn fx:id="colStockProduit" text="Stock" prefWidth="80" style="-fx-alignment: CENTER;"/>
                            </columns>
                            <columnResizePolicy>
                               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        
                        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #ECF0F1; -fx-background-radius: 5;">
                            <Label text="Quantité:" style="-fx-font-weight: bold;"/>
                            <Spinner fx:id="spinnerQuantite" prefWidth="100" editable="true" styleClass="text-field"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Ajouter au Panier 🛒" onAction="#actionAjouterPanier" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                </left>
                
                <center>
                    <Region prefWidth="20"/>
                </center>

                <right>
                    <VBox spacing="15" prefWidth="500" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-background-radius: 5;">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="🛒 Panier en cours" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblDate" text="Date" style="-fx-text-fill: #95A5A6; -fx-font-size: 12px;"/>
                        </HBox>
                        
                        <Separator/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="👤 Client:" style="-fx-font-weight: bold; -fx-text-fill: #7F8C8D;"/>
                            <ComboBox fx:id="comboClient" promptText="-- Client de Passage --" prefWidth="280" style="-fx-background-color: #F5F6FA; -fx-border-color: #BDC3C7;"/>
                            <Button text="➕ Nouveau" onAction="#handleNouveauClient" style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-size: 11px; -fx-padding: 5 10; -fx-cursor: hand;"/>
                        </HBox>
                        
                        <TableView fx:id="tablePanier" VBox.vgrow="ALWAYS" style="-fx-base: white; -fx-selection-bar: #dfe6e9; -fx-selection-bar-non-focused: #dfe6e9;">
                            <columns>
                                <TableColumn fx:id="colPanierProduit" text="Article" prefWidth="200"/>
                                <TableColumn fx:id="colPanierQuantite" text="Qté" prefWidth="50" style="-fx-alignment: CENTER;"/>
                                <TableColumn fx:id="colPanierPrix" text="P.U." prefWidth="80" style="-fx-alignment: CENTER-RIGHT;"/>
                                <TableColumn fx:id="colPanierTotal" text="Total" prefWidth="80" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #27AE60;"/>
                            </columns>
                             <columnResizePolicy>
                               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button text="❌ Retirer" onAction="#actionRetirerPanier" style="-fx-background-color: white; -fx-border-color: #E74C3C; -fx-text-fill: #E74C3C; -fx-cursor: hand;"/>
                            <Button text="🗑️ Vider" onAction="#actionViderPanier" style="-fx-text-fill: #95A5A6; -fx-background-color: transparent; -fx-cursor: hand; -fx-underline: true;"/>
                        </HBox>
                        
                        <Separator/>
                        
                        <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10; -fx-background-color: #F8F9FA; -fx-background-radius: 5;">
                            <VBox alignment="CENTER_RIGHT">
                                <Label text="Total à payer" style="-fx-font-size: 14px; -fx-text-fill: #7F8C8D;"/>
                                <Label fx:id="labelTotal" text="0.000 TND" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
                            </VBox>
                        </HBox>
                        
                        <Button fx:id="btnValiderVente" text="VALIDER LA VENTE ✅" onAction="#actionValiderVente" 
                                maxWidth="Infinity" disable="true"
                                style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(52, 152, 219, 0.4), 10, 0, 0, 0);"/>
                    </VBox>
                </right>
            </BorderPane>
        </Tab>
        
        <!-- TAB 2: Historique des Ventes -->
        <Tab text="📜 Historique">
            <VBox spacing="20" style="-fx-padding: 20;">
                <!-- Filtres de recherche -->
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
                    <Label text="🔍 Recherche:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                    
                    <VBox spacing="5">
                        <Label text="Date début" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px;"/>
                        <DatePicker fx:id="dateDebut" promptText="Date début" prefWidth="150"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Date fin" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px;"/>
                        <DatePicker fx:id="dateFin" promptText="Date fin" prefWidth="150"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Client" style="-fx-text-fill: #7F8C8D; -fx-font-size: 11px;"/>
                        <ComboBox fx:id="comboClientRecherche" promptText="Tous les clients" prefWidth="200"/>
                    </VBox>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <VBox spacing="5" alignment="BOTTOM_RIGHT">
                        <Label text=" " style="-fx-font-size: 11px;"/>
                        <Button text="Rechercher" onAction="#handleRechercherVentes" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </VBox>
                    
                    <VBox spacing="5" alignment="BOTTOM_RIGHT">
                        <Label text=" " style="-fx-font-size: 11px;"/>
                        <Button text="Réinitialiser" onAction="#handleResetRecherche" style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
                
                <!-- Table des ventes -->
                <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 0; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 0);">
                    <TableView fx:id="tableHistoriqueVentes" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colHistoId" text="N° Vente" prefWidth="80" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colHistoDate" text="Date" prefWidth="150" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colHistoClient" text="Client" prefWidth="200"/>
                            <TableColumn fx:id="colHistoTotal" text="Total (TND)" prefWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                            <TableColumn fx:id="colHistoUtilisateur" text="Caissier" prefWidth="150"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
                
                <!-- Actions -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="🔄 Actualiser" onAction="#handleActualiserHistorique" style="-fx-background-color: white; -fx-border-color: #BDC3C7; -fx-cursor: hand;"/>
                    <Button fx:id="btnVoirDetails" text="👁️ Voir Détails" disable="true" onAction="#handleVoirDetails" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Button fx:id="btnSupprimerVente" text="🗑️ Supprimer" disable="true" onAction="#handleSupprimerVente" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
    
</AnchorPane>