<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@../css/pharmacy-blue-theme.css" styleClass="root" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.ui.controller.GestionVentesController">
    <children>
        <VBox spacing="25" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- En-tête -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Gestion des Ventes" styleClass="label-title"/>
                        <Label text="Point de vente et historique des transactions" style="-fx-font-size: 14px; -fx-text-fill: -fx-color-text-muted;"/>
                    </VBox>
                    <Button text="🔄 Actualiser" onAction="#handleRafraichir" styleClass="btn-secondary"/>
                </HBox>

                <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <!-- Vente Comptoir -->
                        <Tab text="Nouvelle Vente">
                            <content>
                                <BorderPane style="-fx-background-color: -fx-color-bg-body; -fx-padding: 30;">
                                    <left>
                                        <VBox prefWidth="550" spacing="15" BorderPane.alignment="CENTER">
                                            <padding>
                                                <Insets right="10" />
                                            </padding>
                                            <children>
                                                <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
                                                    <children>
                                                        <Label styleClass="label-subheading" text="📚 Catalogue Produits" />
                                                        
                                                        <VBox spacing="5">
                                                            <children>
                                                                <Label text="Recherche rapide" styleClass="label-form"/>
                                                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-container">
                                                                    <children>
                                                                        <Label text="🔍" styleClass="search-icon" />
                                                                        <TextField fx:id="fieldRechercheProduit" promptText="Nom ou Code-barres..." styleClass="search-input" HBox.hgrow="ALWAYS" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                        
                                                        <TableView fx:id="tableProduits" VBox.vgrow="ALWAYS">
                                                            <columns>
                                                                <TableColumn fx:id="colNomProduit" prefWidth="250" text="Désignation" />
                                                                <TableColumn fx:id="colPrixProduit" prefWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" text="P.U. (TND)" />
                                                                <TableColumn fx:id="colStockProduit" prefWidth="80" style="-fx-alignment: CENTER;" text="Stock" />
                                                            </columns>
                                                            <columnResizePolicy>
                                                               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                            </columnResizePolicy>
                                                        </TableView>
                                                        
                                                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 0 0 0;">
                                                            <children>
                                                                <VBox spacing="5">
                                                                    <children>
                                                                        <Label text="Quantité" styleClass="label-form" />
                                                                        <Spinner fx:id="spinnerQuantite" editable="true" prefWidth="120" styleClass="spinner" />
                                                                    </children>
                                                                </VBox>
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Button onAction="#actionAjouterPanier" styleClass="button, btn-success" text="Ajouter au Panier" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </left>
                                    
                                    <center>
                                        <VBox spacing="15" BorderPane.alignment="CENTER">
                                            <padding>
                                                <Insets left="10" />
                                            </padding>
                                            <children>
                                                <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                                            <children>
                                                                <Label styleClass="pos-header-icon" text="🛒" />
                                                                <Label styleClass="label-subheading" text="Panier en cours" />
                                                                <Region HBox.hgrow="ALWAYS" />
                                                                <Label fx:id="lblDate" styleClass="label-form" style="-fx-text-fill: -fx-color-text-muted;" text="21/01/2026" />
                                                            </children>
                                                        </HBox>
                                                        
                                                        <Separator />

                                                        <VBox spacing="8">
                                                            <children>
                                                                <Label text="Sélection du Client" styleClass="label-form" />
                                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <ComboBox fx:id="comboClient" promptText="-- Client de Passage --" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="combo-box" style="-fx-min-height: 45;" />
                                                                        <Button onAction="#handleNouveauClient" styleClass="pos-client-add-btn" text="+" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                        
                                                        <TableView fx:id="tablePanier" VBox.vgrow="ALWAYS" styleClass="table-cart">
                                                            <columns>
                                                                <TableColumn fx:id="colPanierProduit" prefWidth="200" text="Article" />
                                                                <TableColumn fx:id="colPanierQuantite" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" text="Qté" />
                                                                <TableColumn fx:id="colPanierPrix" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;" text="P.U. (TND)" />
                                                                <TableColumn fx:id="colPanierTotal" prefWidth="110" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: 800; -fx-text-fill: -fx-color-primary;" text="Total (TND)" />
                                                            </columns>
                                                             <columnResizePolicy>
                                                               <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                            </columnResizePolicy>
                                                            <contextMenu>
                                                                <ContextMenu>
                                                                    <items>
                                                                        <MenuItem text="Retirer du panier" onAction="#actionRetirerPanier" />
                                                                        <MenuItem text="Vider tout le panier" onAction="#actionViderPanier" />
                                                                    </items>
                                                                </ContextMenu>
                                                            </contextMenu>
                                                        </TableView>
                                                        
                                                        <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 5 0;">
                                                            <children>
                                                                <Button onAction="#actionRetirerPanier" styleClass="btn-secondary" text="Retirer Article" style="-fx-text-fill: #EF4444; -fx-border-color: #FEE2E2;" />
                                                                <Button onAction="#actionViderPanier" styleClass="btn-secondary" text="Vider Panier" />
                                                            </children>
                                                        </HBox>
                                                        
                                                        <VBox styleClass="pos-total-card">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <VBox HBox.hgrow="ALWAYS">
                                                                            <children>
                                                                                <Label text="TOTAL À PAYER" styleClass="pos-total-label" />
                                                                                <Label fx:id="labelTotal" styleClass="pos-total-amount" text="0.000 TND" />
                                                                            </children>
                                                                        </VBox>
                                                                        <VBox alignment="CENTER_RIGHT" spacing="0">
                                                                            <children>
                                                                                <Label text="Articles" styleClass="label-form" style="-fx-text-fill: rgba(255,255,255,0.7);"/>
                                                                                <Label fx:id="lblNbArticles" text="0" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                                                                            </children>
                                                                        </VBox>
                                                                    </children>
                                                                </HBox>
                                                                <Button fx:id="btnValiderVente" disable="true" maxWidth="Infinity" onAction="#actionValiderVente" styleClass="btn-pos-validate" text="VALIDER LA VENTE" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </center>
                                </BorderPane>
                            </content>
                        </Tab>

                        <!-- Historique Tab -->
                        <Tab text="Historique des Ventes">
                            <content>
                                <VBox spacing="20" style="-fx-padding: 30;">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="card">
                                            <children>
                                                <VBox spacing="5" HBox.hgrow="SOMETIMES">
                                                    <children>
                                                        <Label text="Date début" styleClass="label-form" />
                                                        <DatePicker fx:id="dateDebut" promptText="Date début" maxWidth="Infinity" />
                                                    </children>
                                                </VBox>
                                                
                                                <VBox spacing="5" HBox.hgrow="SOMETIMES">
                                                    <children>
                                                        <Label text="Date fin" styleClass="label-form" />
                                                        <DatePicker fx:id="dateFin" promptText="Date fin" maxWidth="Infinity" />
                                                    </children>
                                                </VBox>
                                                
                                                <VBox spacing="5" HBox.hgrow="SOMETIMES">
                                                    <children>
                                                        <Label text="Client" styleClass="label-form" />
                                                        <ComboBox fx:id="comboClientRecherche" promptText="Filtrer par client" maxWidth="Infinity" styleClass="combo-box" />
                                                    </children>
                                                </VBox>
                                                
                                                <HBox spacing="10" alignment="BOTTOM_RIGHT">
                                                    <children>
                                                        <Button onAction="#handleRechercherVentes" styleClass="button" text="Rechercher" />
                                                        <Button onAction="#handleResetRecherche" styleClass="btn-secondary" text="Réinitialiser" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </HBox>
                                        
                                        <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
                                            <children>
                                                <TableView fx:id="tableHistoriqueVentes" VBox.vgrow="ALWAYS">
                                                    <columns>
                                                        <TableColumn fx:id="colHistoId" prefWidth="80" style="-fx-alignment: CENTER;" text="Vente N°" />
                                                        <TableColumn fx:id="colHistoDate" prefWidth="150" style="-fx-alignment: CENTER;" text="Date &amp; Heure" />
                                                        <TableColumn fx:id="colHistoClient" prefWidth="250" text="Client" />
                                                        <TableColumn fx:id="colHistoTotal" prefWidth="120" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" text="Total" />
                                                        <TableColumn fx:id="colHistoUtilisateur" prefWidth="150" text="Vendeur" />
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>
                                        
                                        <HBox alignment="CENTER_RIGHT" spacing="15">
                                            <children>
                                                <Button onAction="#handleActualiserHistorique" styleClass="btn-secondary" text="🔄 Actualiser" />
                                                <Button fx:id="btnVoirDetails" disable="true" onAction="#handleVoirDetails" styleClass="button" text="Voir Détails" />
                                                <Button fx:id="btnSupprimerVente" disable="true" onAction="#handleSupprimerVente" styleClass="btn-danger" text="Supprimer" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
