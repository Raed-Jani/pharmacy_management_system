<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" styleClass="login-root" stylesheets="@../css/pharmacy-blue-theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.ui.controller.LoginController">
    <children>
        <!-- Main Content -->
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="CENTER" spacing="25.0">
                    <children>
                        <VBox alignment="TOP_CENTER" maxWidth="440.0" spacing="35.0" styleClass="login-card-saas">
                            <children>
                                <!-- Branding Header: row-based Logo + Name -->
                                <VBox spacing="25.0" alignment="CENTER">
                                    <children>
                                        <HBox alignment="CENTER" spacing="15.0">
                                            <children>
                                                <!-- Premium Pill Logo -->
                                                <StackPane styleClass="saas-pill-logo">
                                                    <children>
                                                        <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true">
                                                            <image>
                                                               <Image url="@../images/app_icon.png" />
                                                            </image>
                                                         </ImageView>
                                                    </children>
                                                </StackPane>
                                                <Label styleClass="login-brand-name" text="BioVera" />
                                            </children>
                                        </HBox>
                                        
                                        <VBox alignment="CENTER" spacing="5.0">
                                            <children>
                                                <Label styleClass="login-saas-title" text="Login" />
                                                <Label styleClass="login-saas-subtitle" text="Pharmacy Management System" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                                
                                <!-- Form Fields -->
                                <VBox spacing="20.0">
                                    <children>
                                        <VBox spacing="10.0">
                                            <children>
                                                <Label styleClass="login-input-heading" text="Username" />
                                                <HBox styleClass="login-input-container">
                                                    <children>
                                                        <Label styleClass="login-input-icon" text="👤" />
                                                        <TextField fx:id="txtLogin" promptText="Nom d'utilisateur" styleClass="login-input-field" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        
                                        <VBox spacing="10.0">
                                            <children>
                                                <Label styleClass="login-input-heading" text="Password" />
                                                <HBox styleClass="login-input-container">
                                                    <children>
                                                        <Label styleClass="login-input-icon" text="🔒" />
                                                        <PasswordField fx:id="txtPassword" promptText="Mot de passe" styleClass="login-input-field" HBox.hgrow="ALWAYS" />
                                                        <Label styleClass="login-input-icon-eye" text="👁" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                                
                                <!-- Options -->
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <CheckBox mnemonicParsing="false" styleClass="login-checkbox" text="Remember me" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Hyperlink styleClass="login-link" text="Forgot Password?" />
                                    </children>
                                </HBox>
                                
                                <!-- Actions -->
                                <VBox spacing="15.0" alignment="CENTER">
                                    <children>
                                        <StackPane>
                                            <children>
                                                <Button fx:id="btnLogin" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" styleClass="btn-primary-saas" text="Login" />
                                                <ProgressIndicator fx:id="progressIndicator" visible="false" maxHeight="25.0" maxWidth="25.0" />
                                            </children>
                                        </StackPane>
                                        <Label fx:id="lblError" style="-fx-text-fill: #EF4444; -fx-font-size: 13px; -fx-font-weight: 500;" visible="false" wrapText="true" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                        
                        <!-- Page Footer -->
                        <Label styleClass="login-footer-saas" text="© 2026 BioVera — Pharmacy Management System" />
                        <Hyperlink onAction="#handleQuitter" styleClass="login-link-muted" text="Exit System" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>