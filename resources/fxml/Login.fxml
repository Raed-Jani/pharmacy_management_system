<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="blue-gradient-bg" stylesheets="@../css/pharmacy-blue-theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.ui.controller.LoginController">
    
    <!-- Connection Status Indicator (Top Right) -->
    <HBox alignment="CENTER_RIGHT" spacing="8" AnchorPane.topAnchor="20" AnchorPane.rightAnchor="20">
        <Label text="Database:" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12px;" />
        <Circle fx:id="statusIndicator" radius="6" styleClass="status-connected" />
    </HBox>
    
    <!-- Main Login Card -->
    <VBox alignment="CENTER" spacing="30" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        
        <!-- Login Card Container -->
        <VBox alignment="CENTER" spacing="25" prefWidth="450" styleClass="glass-card" style="-fx-padding: 40;">
            
            <!-- Medical Cross Icon -->
            <Label text="⚕" styleClass="medical-cross" />
            
            <!-- Title -->
            <VBox alignment="CENTER" spacing="8">
                <Label text="Système de Gestion" styleClass="label-title" style="-fx-text-fill: #1A237E;" />
                <Label text="PHARMACIE" styleClass="label-title" style="-fx-text-fill: #283593; -fx-font-size: 28px;" />
                <Label text="Connexion Sécurisée" styleClass="label-muted" style="-fx-font-size: 14px; -fx-padding: 10 0 0 0;" />
            </VBox>
            
            <!-- Login Form -->
            <VBox spacing="20" prefWidth="350">
                
                <!-- Username Field -->
                <VBox spacing="8">
                    <Label text="Nom d'utilisateur" styleClass="label-heading" style="-fx-font-size: 14px; -fx-text-fill: #1A237E;" />
                    <TextField fx:id="txtLogin" promptText="Entrez votre identifiant" styleClass="text-field-blue" />
                </VBox>
                
                <!-- Password Field -->
                <VBox spacing="8">
                    <Label text="Mot de passe" styleClass="label-heading" style="-fx-font-size: 14px; -fx-text-fill: #1A237E;" />
                    <PasswordField fx:id="txtPassword" promptText="Entrez votre mot de passe" styleClass="password-field-blue" />
                </VBox>
                
                <!-- Error Message -->
                <Label fx:id="lblError" visible="false" wrapText="true" style="-fx-text-fill: #D32F2F; -fx-font-weight: bold; -fx-background-color: #FFEBEE; -fx-padding: 10; -fx-background-radius: 8;" />
                
                <!-- Progress Indicator -->
                <HBox alignment="CENTER">
                    <ProgressIndicator fx:id="progressIndicator" visible="false" maxHeight="40" maxWidth="40" styleClass="progress-indicator" />
                </HBox>
                
                <!-- Buttons -->
                <HBox spacing="15" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                    <Button fx:id="btnLogin" text="Se Connecter" onAction="#handleLogin" prefWidth="180" styleClass="btn-primary">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Button>
                    <Button text="Quitter" onAction="#handleQuitter" prefWidth="120" styleClass="btn-secondary">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Button>
                </HBox>
            </VBox>
            
            <!-- Help Section -->
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 20 0 0 0; -fx-border-color: #E3F2FD; -fx-border-width: 1 0 0 0;">
                <Label text="Identifiants par défaut" styleClass="label-muted" style="-fx-font-size: 11px; -fx-padding: 10 0 0 0;" />
                <Label text="Login: admin  •  Mot de passe: password123" styleClass="label-muted" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #283593;" />
            </VBox>
            
        </VBox>
        
        <!-- Footer -->
        <Label text="© 2026 Pharmacy Management System - Professional Edition" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;" />
        
    </VBox>
    
</AnchorPane>