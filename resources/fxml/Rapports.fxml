<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="frost-blue-bg" stylesheets="@../css/pharmacy-blue-theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.ui.controller.RapportsController">

    <VBox spacing="25" AnchorPane.bottomAnchor="25" AnchorPane.leftAnchor="25" AnchorPane.rightAnchor="25" AnchorPane.topAnchor="25">
        
        <!-- Header Section with Export Controls -->
        <VBox spacing="15" styleClass="glass-card" style="-fx-padding: 20;">
            <Label text="📊 Rapports et Statistiques" styleClass="label-title"/>
            
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="Format d'export:" styleClass="label-heading" style="-fx-font-size: 13px;"/>
                <ComboBox fx:id="comboFormat" prefWidth="110" styleClass="combo-box-blue"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleExportProduits" styleClass="btn-primary" text="📄 Exporter Produits" />
                <Button onAction="#handleExportVentes" styleClass="btn-primary" text="💰 Exporter Ventes" />
            </HBox>
        </VBox>

        <!-- KPI Cards Section -->
        <HBox spacing="20" alignment="CENTER">
            <!-- Card CA -->
            <VBox prefWidth="240" styleClass="glass-card" spacing="8" style="-fx-padding: 25; -fx-border-color: #042d62; -fx-border-width: 0 0 0 5;">
                <Label text="💰" style="-fx-font-size: 40px; -fx-text-fill: #042d62;" />
                <Label text="Chiffre d'Affaires" styleClass="label-muted" />
                <Label fx:id="lblTotalCA" text="0.00 TND" styleClass="label-title" style="-fx-font-size: 24px; -fx-text-fill: #042d62;" />
            </VBox>

            <!-- Card Ventes -->
            <VBox prefWidth="240" styleClass="glass-card" spacing="8" style="-fx-padding: 25; -fx-border-color: #096b08; -fx-border-width: 0 0 0 5;">
                <Label text="🛒" style="-fx-font-size: 40px; -fx-text-fill: #096b08;" />
                <Label text="Total Ventes" styleClass="label-muted" />
                <Label fx:id="lblTotalVentes" text="0" styleClass="label-title" style="-fx-font-size: 24px; -fx-text-fill: #096b08;" />
            </VBox>

            <!-- Card Top Produit -->
            <VBox prefWidth="240" styleClass="glass-card" spacing="8" style="-fx-padding: 25; -fx-border-color: #88dcff; -fx-border-width: 0 0 0 5;">
                <Label text="⭐" style="-fx-font-size: 40px; -fx-text-fill: #88dcff;" />
                <Label text="Top Produit" styleClass="label-muted" />
                <Label fx:id="lblTopProduit" text="-" styleClass="label-heading" style="-fx-font-size: 18px; -fx-text-fill: #88dcff;" />
            </VBox>
        </HBox>

        <!-- Charts Section -->
        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <!-- Bar Chart Container -->
            <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="10" style="-fx-padding: 20;">
                <Label text="📈 CA des 7 derniers jours" styleClass="label-heading" />
                <BarChart fx:id="barChartCA" styleClass="chart" VBox.vgrow="ALWAYS" legendVisible="false">
                    <xAxis>
                        <CategoryAxis fx:id="xAxisCA" label="Date" side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis fx:id="yAxisCA" label="CA (TND)" side="LEFT" />
                    </yAxis>
                </BarChart>
            </VBox>
            
            <!-- Pie Chart Container -->
            <VBox styleClass="glass-card" HBox.hgrow="ALWAYS" spacing="10" style="-fx-padding: 20;">
                <Label text="🏆 Top 5 Produits vendus" styleClass="label-heading" />
                <PieChart fx:id="pieChartProduits" styleClass="chart" VBox.vgrow="ALWAYS" />
            </VBox>
        </HBox>

    </VBox>

</AnchorPane>
