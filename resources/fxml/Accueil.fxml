<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmacie.ui.controller.AccueilController"
            fx:id="scrollPane"
            fitToWidth="true"
            styleClass="scroll-pane"
            stylesheets="@../css/pharmacy-blue-theme.css">
    
    <VBox spacing="35" style="-fx-padding: 40; -fx-background-color: transparent;">
        
        <!-- HEADER ENHANCED -->
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Tableau de Bord" styleClass="label-title"/>
                <Label text="Analyse en temps réel de votre officine" styleClass="label-muted"/>
            </VBox>
            <Button text="🔄 Actualiser" onAction="#refreshData" styleClass="quick-action-btn" 
                    style="-fx-background-color: transparent; -fx-text-fill: -fx-primary-dark; -fx-border-color: -fx-primary-dark; -fx-border-radius: 10; -fx-effect: none;"/>
        </HBox>

        <!-- DYNAMIC ALERTS (TOP-SHELF GLASS SECTION) -->
        <VBox spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="⚠ Alertes Critiques" styleClass="label-heading" style="-fx-text-fill: -fx-danger;"/>
            </HBox>
            <VBox fx:id="vboxStockAlerts" spacing="12" styleClass="stock-alert-container">
                <Label text="Aucune alerte critique pour le moment." styleClass="label-muted" style="-fx-padding: 10;"/>
            </VBox>
        </VBox>

        <!-- QUICK ACTION BAR (MODERN BUTTONS) -->
        <VBox spacing="15">
            <Label text="Raccourcis" styleClass="label-heading"/>
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Button fx:id="btnQuickSale" text="💰 Nouvelle Vente" onAction="#handleNewSale" styleClass="quick-action-btn" prefWidth="240"/>
                <Button fx:id="btnQuickOrder" text="📦 Commandes" onAction="#handleNewOrder" styleClass="quick-action-btn" prefWidth="240"/>
                <Button fx:id="btnQuickRapports" text="📈 Rapports" onAction="#handleGoToRapports" styleClass="quick-action-btn" prefWidth="240"/>
                <Button fx:id="btnQuickUtilisateurs" text="⚙ Gestion" onAction="#handleGoToUtilisateurs" styleClass="quick-action-btn" prefWidth="240"/>
            </HBox>
        </VBox>
        
        <!-- DASHBOARD STATS (ELEVATED CARDS) -->
        <GridPane hgap="25" vgap="25">
            <columnConstraints>
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
            </columnConstraints>
            
            <VBox styleClass="info-card" spacing="15" GridPane.columnIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="info-card-icon-box,info-card-icon-blue" minWidth="45" minHeight="45"/>
                    <Label text="Produits" styleClass="info-card-title"/>
                </HBox>
                <Label fx:id="lblTotalProducts" text="--" styleClass="info-card-value"/>
            </VBox>
            
            <VBox styleClass="info-card" spacing="15" GridPane.columnIndex="1">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="info-card-icon-box,info-card-icon-orange" minWidth="45" minHeight="45"/>
                    <Label text="Alertes Stock" styleClass="info-card-title"/>
                </HBox>
                <Label fx:id="lblLowStockItems" text="--" styleClass="info-card-value"/>
            </VBox>
            
            <VBox styleClass="info-card" spacing="15" GridPane.columnIndex="2">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="info-card-icon-box,info-card-icon-green" minWidth="45" minHeight="45"/>
                    <Label text="Ventes (Aujourd'hui)" styleClass="info-card-title"/>
                </HBox>
                <Label fx:id="lblTodaysSales" text="--" styleClass="info-card-value"/>
            </VBox>
            
            <VBox styleClass="info-card" spacing="15" GridPane.columnIndex="3">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="info-card-icon-box,info-card-icon-purple" minWidth="45" minHeight="45"/>
                    <Label text="Commandes" styleClass="info-card-title"/>
                </HBox>
                <Label fx:id="lblPendingOrders" text="--" styleClass="info-card-value"/>
            </VBox>
        </GridPane>
        
        <!-- RECENT ACTIVITY (CLEAN LIST) -->
        <VBox spacing="20" styleClass="glass-card" style="-fx-padding: 30;">
            <Label text="Dernières Activités" styleClass="label-heading"/>
            <VBox fx:id="vboxActivites" spacing="5">
                <!-- Dynamically populated -->
                <Label text="Chargement de l'activité..." styleClass="label-muted"/>
            </VBox>
        </VBox>
        
    </VBox>
</ScrollPane>
