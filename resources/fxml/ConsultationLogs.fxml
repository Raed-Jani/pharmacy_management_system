<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../css/pharmacy-blue-theme.css" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacie.ui.controller.ConsultationLogsController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <!-- En-tête -->
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 0 0 10 0;">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Consultation des Logs" styleClass="label-title"/>
                    <Label text="Historique des actions et activités système" style="-fx-font-size: 14px; -fx-text-fill: -fx-color-text-muted;"/>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleRafraichir" styleClass="btn-secondary" text="🔄 Actualiser" />
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="card">
               <children>
                  <Label text="Filtrer par type:" style="-fx-font-weight: bold;"/>
                  <TextField fx:id="txtFiltreType" promptText="Rechercher un type..." prefWidth="250.0" styleClass="search-bar" />
               </children>
            </HBox>
            
            <VBox styleClass="card" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
                <TableView fx:id="tableLogs" VBox.vgrow="ALWAYS">
                  <columns>
                    <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                    <TableColumn fx:id="colDate" prefWidth="180.0" text="Date et Heure" />
                      <TableColumn fx:id="colType" prefWidth="150.0" text="Type d'Action" />
                      <TableColumn fx:id="colDescription" prefWidth="300.0" text="Description" />
                      <TableColumn fx:id="colUtilisateur" prefWidth="100.0" text="ID Utilisateur" />
                  </columns>
                   <columnResizePolicy>
                      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                   </columnResizePolicy>
                </TableView>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
